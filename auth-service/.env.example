# =====================================================
# Auth Service – Konfiguration
# Kopiere diese Datei zu .env und passe Werte an.
# =====================================================

# --- App ---
APP_NAME=nadini-auth
APP_ENV=development          # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8001
LOG_LEVEL=INFO
LOG_FORMAT=json              # json | console

# --- Datenbank ---
DATABASE_URL=postgresql+asyncpg://admin:devpass@postgres:5432/nadini
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# --- Redis (Rate Limiting) ---
REDIS_URL=redis://redis:6379/0

# --- JWT ---
# Privat-/Public-Key sind im Container unter /secrets gemountet (siehe scripts/generate_keys.sh).
JWT_PRIVATE_KEY_PATH=/secrets/jwt-private.pem
JWT_PUBLIC_KEY_PATH=/secrets/jwt-public.pem
JWT_ISSUER=https://api.nadini.local
JWT_AUDIENCE=nadini
ACCESS_TOKEN_TTL_SECONDS=900           # 15 Minuten
REFRESH_TOKEN_TTL_SECONDS=2592000      # 30 Tage

# --- Magic Link ---
MAGIC_LINK_BASE_URL=https://app.nadini.local
MAGIC_LINK_TTL_SECONDS=300             # 5 Minuten
MAGIC_LINK_RATE_PER_EMAIL=3            # Anfragen pro Fenster
MAGIC_LINK_RATE_PER_IP=10
MAGIC_LINK_RATE_WINDOW_SECONDS=900     # 15 Minuten
MAGIC_LINK_VERIFY_RATE_PER_IP=10

# --- Mailer (Resend) ---
MAILER_DRIVER=resend                   # resend | console (für lokale Tests ohne API-Key)
RESEND_API_KEY=re_your_api_key_here
MAIL_FROM=no-reply@nadini.local
MAIL_FROM_NAME=Nadini

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
